{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "emede",
  "version": "0.1.8",
  "identifier": "com.emede.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "emede",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "visible": false,
        "backgroundColor": "#faf8f5"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost https: data: blob:",
        "font-src": "'self' asset: http://asset.localhost data:",
        "connect-src": "'self' ipc: http://ipc.localhost"
      },
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": true,
          "allow": ["**/*"]
        }
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "Read markdown files",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "multiple": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

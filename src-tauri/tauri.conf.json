{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "emede",
  "version": "0.1.0",
  "identifier": "com.jesus.emede",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "emede",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "visible": false,
        "backgroundColor": "#faf8f5"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Read markdown files",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "multiple": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
